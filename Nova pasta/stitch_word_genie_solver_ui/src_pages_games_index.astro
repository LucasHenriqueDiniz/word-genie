---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Choose Your Challenge - Word Genie">
  <main class="min-h-screen bg-[#020617] flex flex-col md:flex-row overflow-hidden relative">
    
    <!-- Gartic Side -->
    <div class="flex-1 relative group overflow-hidden">
      <!-- Background Image -->
      <div class="absolute inset-0 z-0">
        <img 
          src="{{DATA:IMAGE:IMAGE_24}}" 
          alt="Gartic Background" 
          class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110"
        />
        <div class="absolute inset-0 bg-blue-600/80 mix-blend-multiply"></div>
        <div class="absolute inset-0 bg-gradient-to-r from-blue-900 via-transparent to-transparent opacity-80"></div>
      </div>

      <!-- Content -->
      <div class="relative z-10 h-full flex flex-col justify-center px-12 lg:px-24 py-32 space-y-8">
        <div class="inline-block px-4 py-1.5 bg-blue-400/20 backdrop-blur-md border border-blue-400/30 rounded-lg text-white font-bold text-sm tracking-wide self-start">
          12,500+ WORDS DETECTED
        </div>
        
        <div class="space-y-4">
          <h2 class="text-white text-5xl lg:text-7xl font-black tracking-tight">Gartic Phone & IO</h2>
          <p class="text-blue-100 text-xl max-w-md leading-relaxed opacity-90">
            Master the art of guessing. Our linguistic engine processes hints and word lengths in real-time to find your match.
          </p>
        </div>

        <div class="flex flex-wrap gap-4 pt-4">
          <a 
            href="/games/gartic" 
            class="px-10 py-5 bg-white text-blue-600 font-black rounded-xl hover:bg-blue-50 transition-all flex items-center gap-3 shadow-2xl shadow-blue-900/50 group/btn"
          >
            Play Now
            <svg class="w-5 h-5 group-hover/btn:translate-x-1 group-hover/btn:-translate-y-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M13 10V3L4 14h7v7l9-11h-7z"/>
            </svg>
          </a>
          <button class="px-10 py-5 bg-blue-950/30 backdrop-blur-xl border border-blue-400/30 text-white font-bold rounded-xl hover:bg-blue-400/20 transition-all">
            View Database
          </button>
        </div>
      </div>
    </div>

    <!-- Divider (Vertical Text) -->
    <div class="hidden lg:flex absolute left-1/2 top-1/2 -translate-x-1/2 -translate-y-1/2 z-20 flex-col items-center gap-8">
       <div class="h-32 w-px bg-white/20"></div>
       <span class="text-white/40 font-black tracking-widest text-xs uppercase vertical-text">Versus</span>
       <div class="h-32 w-px bg-white/20"></div>
    </div>

    <!-- GTB Side -->
    <div class="flex-1 relative group overflow-hidden">
      <!-- Background Image -->
      <div class="absolute inset-0 z-0">
        <img 
          src="{{DATA:IMAGE:IMAGE_24}}" 
          alt="GTB Background" 
          class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110 grayscale"
        />
        <div class="absolute inset-0 bg-orange-800/90 mix-blend-multiply"></div>
        <div class="absolute inset-0 bg-gradient-to-l from-orange-950 via-transparent to-transparent opacity-80"></div>
      </div>

      <!-- Content -->
      <div class="relative z-10 h-full flex flex-col justify-center items-end px-12 lg:px-24 py-32 space-y-8 text-right">
        <div class="inline-block px-4 py-1.5 bg-orange-400/20 backdrop-blur-md border border-orange-400/30 rounded-lg text-white font-bold text-sm tracking-wide">
          5,800+ THEMES LOGGED
        </div>
        
        <div class="space-y-4">
          <h2 class="text-white text-5xl lg:text-7xl font-black tracking-tight">Guess The Build</h2>
          <p class="text-orange-100 text-xl max-w-md leading-relaxed opacity-90 ml-auto">
            Level up your creative game. Optimized for theme categories and building prompts across popular sandbox titles.
          </p>
        </div>

        <div class="flex flex-wrap gap-4 pt-4 justify-end">
          <button class="px-10 py-5 bg-orange-950/30 backdrop-blur-xl border border-orange-400/30 text-white font-bold rounded-xl hover:bg-orange-400/20 transition-all">
            Browse Themes
          </button>
          <a 
            href="/games/guess-build" 
            class="px-10 py-5 bg-white text-orange-700 font-black rounded-xl hover:bg-orange-50 transition-all flex items-center gap-3 shadow-2xl shadow-orange-900/50 group/btn"
          >
            Play Now
            <svg class="w-5 h-5 group-hover/btn:rotate-12 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M11 4a2 2 0 114 0v1a1 1 0 001 1h3a1 1 0 011 1v3a1 1 0 01-1 1h-1a2 2 0 100 4h1a1 1 0 011 1v3a1 1 0 01-1 1h-3a1 1 0 01-1-1v-1a2 2 0 10-4 0v1a1 1 0 01-1 1H7a1 1 0 01-1-1v-3a1 1 0 011-1h1a2 2 0 100-4H7a1 1 0 01-1-1V7a1 1 0 011-1h3a1 1 0 011 1V4z"/>
            </svg>
          </a>
        </div>
      </div>
    </div>

    <!-- Center Nav Link -->
    <a href="/" class="absolute top-8 left-1/2 -translate-x-1/2 z-30 flex items-center gap-2 group">
      <div class="w-10 h-10 bg-white rounded-lg flex items-center justify-center text-slate-900 group-hover:scale-110 transition-transform">
        <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 20 20"><path d="M10.707 2.293a1 1 0 00-1.414 0l-7 7a1 1 0 001.414 1.414L4 10.414V17a1 1 0 001 1h2a1 1 0 001-1v-2a1 1 0 011-1h2a1 1 0 011-1v2a1 1 0 001 1h2a1 1 0 001-1v-6.586l.293.293a1 1 0 001.414-1.414l-7-7z"/></svg>
      </div>
    </a>
  </main>
</Layout>

<style>
  .vertical-text {
    writing-mode: vertical-rl;
  }
</style>