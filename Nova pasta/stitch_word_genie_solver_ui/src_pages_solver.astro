---
import Layout from '../layouts/Layout.astro';
import SimpleSolver from '../components/SimpleSolver.tsx';
import garticWordsData from '../data/words/gartic-real.json';
import gtbWordsData from '../data/words/guess-build-real.json';

// Simulated data fetching (assuming internal JSONs)
const garticWords = garticWordsData || [];
const gtbWords = gtbWordsData || [];

const stats = [
  { label: '15,000+ Words', icon: '📖' },
  { label: 'Instant Results', icon: '⚡' },
  { label: '100% Free', icon: '✅' }
];

const faqs = [
  {
    q: "What is a Gartic word solver?",
    a: "A Gartic word solver is a tool that helps players identify words based on a pattern of letters and blanks. It's essential for competitive play in Gartic.io and Gartic Phone."
  },
  {
    q: "How do I use the pattern matcher for Guess Build?",
    a: "Simply enter the known letters and use underscores (_) for unknown characters. For example, 'c_t' will find 'cat', 'cot', etc. The matcher updates in real-time as you type."
  },
  {
    q: "Is Word Genie free to use?",
    a: "Yes, Word Genie is a 100% free web-based utility designed for the gaming community. No registration or payment required."
  },
  {
    q: "Can I use this for crosswords?",
    a: "Absolutely! While optimized for Gartic and Guess Build, the pattern matching engine works perfectly for crosswords and other word-based puzzle games."
  },
  {
    q: "Does Word Genie support other languages?",
    a: "Currently, we focus on high-performance English word lists, but we are expanding our database to include Portuguese, Spanish, and French lists soon."
  }
];
---

<Layout title="Word Genie Solver - Solve Gartic & Guess Build Patterns">
  <main className="min-h-screen bg-slate-50 dark:bg-slate-950">
    
    {/* Hero Section */}
    <section className="pt-20 pb-12 px-4 text-center max-w-4xl mx-auto">
      <h1 className="text-4xl md:text-6xl font-extrabold text-slate-900 dark:text-white mb-6 tracking-tight">
        Word Genie <span className="text-blue-600">Solver</span>
      </h1>
      <p className="text-lg md:text-xl text-slate-600 dark:text-slate-400 max-w-2xl mx-auto leading-relaxed">
        The ultimate pattern matching tool for Gartic and Guess Build. Solve complex words instantly with our high-performance linguistic engine.
      </p>
    </section>

    {/* Solver Section */}
    <section className="px-4 pb-20">
      <SimpleSolver 
        client:load 
        words={garticWords} 
        game="gartic" 
        placeholder="Enter word pattern (e.g., ele____)" 
      />
    </section>

    {/* Stats Bar */}
    <div className="bg-blue-50 dark:bg-blue-900/20 py-8 border-y border-blue-100 dark:border-blue-800">
      <div className="max-w-6xl mx-auto px-4 flex flex-wrap justify-center gap-8 md:gap-24">
        {stats.map(stat => (
          <div key={stat.label} className="flex items-center gap-3">
            <span className="text-2xl">{stat.icon}</span>
            <span className="font-bold text-slate-700 dark:text-slate-200">{stat.label}</span>
          </div>
        ))}
      </div>
    </div>

    {/* How to Use */}
    <section className="py-24 px-4 max-w-6xl mx-auto">
      <h2 className="text-3xl font-bold text-center mb-16 dark:text-white">How to Win More Games</h2>
      <div className="grid md:grid-cols-3 gap-12">
        <div className="text-center space-y-4">
          <div className="w-16 h-16 bg-blue-600 text-white rounded-2xl flex items-center justify-center text-2xl font-bold mx-auto shadow-lg shadow-blue-500/20">1</div>
          <h3 className="text-xl font-bold dark:text-white">Enter Pattern</h3>
          <p className="text-slate-600 dark:text-slate-400">Type the letters you know and use underscores for blanks.</p>
        </div>
        <div className="text-center space-y-4">
          <div className="w-16 h-16 bg-blue-600 text-white rounded-2xl flex items-center justify-center text-2xl font-bold mx-auto shadow-lg shadow-blue-500/20">2</div>
          <h3 className="text-xl font-bold dark:text-white">See Results</h3>
          <p className="text-slate-600 dark:text-slate-400">Word Genie filters thousands of dictionary entries in real-time.</p>
        </div>
        <div className="text-center space-y-4">
          <div className="w-16 h-16 bg-blue-600 text-white rounded-2xl flex items-center justify-center text-2xl font-bold mx-auto shadow-lg shadow-blue-500/20">3</div>
          <h3 className="text-xl font-bold dark:text-white">Copy & Play</h3>
          <p className="text-slate-600 dark:text-slate-400">Click the best match to copy it and win your round instantly.</p>
        </div>
      </div>
    </section>

    {/* Pattern Examples */}
    <section className="py-20 bg-white dark:bg-slate-900 border-y border-slate-100 dark:border-slate-800 px-4">
      <div className="max-w-4xl mx-auto">
        <h2 className="text-3xl font-bold mb-10 dark:text-white">Example Patterns</h2>
        <div className="space-y-4">
          <div className="p-6 bg-slate-50 dark:bg-slate-800 rounded-2xl flex justify-between items-center border border-slate-100 dark:border-slate-700">
            <div>
              <p className="text-blue-600 font-bold text-xs uppercase tracking-wider mb-1">Simple Match</p>
              <p className="font-mono text-xl dark:text-white">c_t</p>
            </div>
            <p className="text-slate-500 font-bold">CAT, COT, CUT</p>
          </div>
          <div className="p-6 bg-slate-50 dark:bg-slate-800 rounded-2xl flex justify-between items-center border border-slate-100 dark:border-slate-700">
            <div>
              <p className="text-blue-600 font-bold text-xs uppercase tracking-wider mb-1">Complex Match</p>
              <p className="font-mono text-xl dark:text-white">p_tt_rn</p>
            </div>
            <p className="text-slate-500 font-bold">PATTERN, POTTERN</p>
          </div>
        </div>
      </div>
    </section>

    {/* FAQ Section */}
    <section className="py-24 px-4 max-w-3xl mx-auto">
      <h2 className="text-3xl font-bold mb-12 text-center dark:text-white">Frequently Asked Questions</h2>
      <div className="space-y-8">
        {faqs.map(faq => (
          <div key={faq.q} className="group">
            <h3 className="text-lg font-bold mb-3 text-slate-800 dark:text-slate-200 group-hover:text-blue-600 transition-colors">
              {faq.q}
            </h3>
            <p className="text-slate-600 dark:text-slate-400 leading-relaxed">
              {faq.a}
            </p>
          </div>
        ))}
      </div>
    </section>

  </main>
</Layout>