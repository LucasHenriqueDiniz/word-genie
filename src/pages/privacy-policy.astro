---
import Layout from '../components/Layout.astro';

const title = 'Privacy Policy | Word Genie';
const description = 'Learn how Word Genie handles your data and privacy.';
---

<Layout title={title} description={description}>
  <!-- Breadcrumb -->
  <div class="container-main py-4 text-sm">
    <a href="/" class="text-blue-600 hover:underline">Home</a> /
    <span class="text-gray-600 ml-2">Privacy Policy</span>
  </div>

  <!-- Header -->
  <section class="bg-gray-100 py-12">
    <div class="container-main">
      <h1 class="text-4xl font-bold">Privacy Policy</h1>
      <p class="text-gray-600 mt-2">Last updated: June 26, 2026</p>
    </div>
  </section>

  <!-- Content -->
  <div class="container-main py-12 max-w-3xl prose prose-lg prose-sm">
    <section class="mb-8">
      <h2 class="text-2xl font-bold mb-4">Introduction</h2>
      <p class="text-gray-700 mb-4">
        Word Genie ("we," "us," "our," or "Company") operates the wordgenie.app website. This Privacy Policy explains our practices regarding the collection, use, and disclosure of your information.
      </p>
    </section>

    <section class="mb-8">
      <h2 class="text-2xl font-bold mb-4">Information We Collect</h2>
      <p class="text-gray-700 mb-4">We collect very limited information:</p>
      <ul class="text-gray-700 space-y-2">
        <li><strong>Usage Analytics:</strong> We use Google Analytics to understand how visitors use our site (pages visited, time spent, etc.)</li>
        <li><strong>Cookies:</strong> Minimal cookies may be used for site functionality and analytics</li>
        <li><strong>Contact Information:</strong> If you email us, we receive your email address and message content</li>
      </ul>
    </section>

    <section class="mb-8">
      <h2 class="text-2xl font-bold mb-4">Information We DO NOT Collect</h2>
      <p class="text-gray-700 mb-4">
        We do NOT collect, store, or require:
      </p>
      <ul class="text-gray-700 space-y-2">
        <li>Personal identification information (names, phone numbers, addresses)</li>
        <li>Financial or payment information</li>
        <li>Location data</li>
        <li>Biometric data</li>
        <li>User account information</li>
      </ul>
    </section>

    <section class="mb-8">
      <h2 class="text-2xl font-bold mb-4">How We Use Information</h2>
      <p class="text-gray-700 mb-4">
        Any information we collect is used only to:
      </p>
      <ul class="text-gray-700 space-y-2">
        <li>Provide and maintain our service</li>
        <li>Understand how visitors use our site</li>
        <li>Respond to your emails and inquiries</li>
        <li>Improve our tools and features</li>
      </ul>
    </section>

    <section class="mb-8">
      <h2 class="text-2xl font-bold mb-4">Third-Party Services</h2>
      <p class="text-gray-700 mb-4">
        Word Genie uses third-party services for analytics:
      </p>
      <ul class="text-gray-700 space-y-2">
        <li><strong>Google Analytics:</strong> Used to analyze website traffic. Please review Google's privacy policy at policies.google.com</li>
        <li><strong>Cloudflare:</strong> Hosting provider. Review Cloudflare's privacy policy at cloudflare.com/privacy</li>
      </ul>
    </section>

    <section class="mb-8">
      <h2 class="text-2xl font-bold mb-4">Data Security</h2>
      <p class="text-gray-700 mb-4">
        We implement appropriate technical and organizational measures to protect your information. Our website uses HTTPS encryption to secure data transmission.
      </p>
    </section>

    <section class="mb-8">
      <h2 class="text-2xl font-bold mb-4">Your Rights</h2>
      <p class="text-gray-700 mb-4">
        You have the right to:
      </p>
      <ul class="text-gray-700 space-y-2">
        <li>Access any personal information we may have about you</li>
        <li>Request deletion of your information</li>
        <li>Opt-out of analytics tracking (configure your browser settings)</li>
      </ul>
    </section>

    <section class="mb-8">
      <h2 class="text-2xl font-bold mb-4">Children's Privacy</h2>
      <p class="text-gray-700 mb-4">
        Word Genie is not directed to children under 13. We do not knowingly collect information from children under 13. If we become aware that a child under 13 has provided us with information, we will delete such information immediately.
      </p>
    </section>

    <section class="mb-8">
      <h2 class="text-2xl font-bold mb-4">Changes to This Policy</h2>
      <p class="text-gray-700 mb-4">
        We may update this Privacy Policy from time to time. Any changes will be reflected on this page with an updated "Last Updated" date. Continued use of Word Genie constitutes your acceptance of any changes.
      </p>
    </section>

    <section>
      <h2 class="text-2xl font-bold mb-4">Contact Us</h2>
      <p class="text-gray-700 mb-4">
        If you have questions about this Privacy Policy, please contact us at:
      </p>
      <p class="text-gray-700">
        <a href="mailto:privacy@wordgenie.app" class="text-blue-600 hover:underline">privacy@wordgenie.app</a>
      </p>
    </section>
  </div>
</Layout>
