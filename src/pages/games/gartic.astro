---
import Layout from '../../components/Layout.astro';
import SimpleSolver from '../../components/SimpleSolver.tsx';
import WordShowcase from '../../components/WordShowcase.tsx';

// Import real word data
import garticWordsData from '../../data/words/gartic-real.json';

const allWords = garticWordsData.words;
const exampleWords = allWords.slice(0, 16);

const categories = [
  { name: "Animals", count: "420+ VERIFIED WORDS", icon: "🐾", color: "blue" },
  { name: "Food", count: "315+ VERIFIED WORDS", icon: "🍴", color: "blue" },
  { name: "Objects", count: "580+ VERIFIED WORDS", icon: "📦", color: "blue" }
];

const steps = [
  { num: 1, title: "Check Length", desc: "Count the underscores in Gartic and set the word length in our Genie tool." },
  { num: 2, title: "Input Hints", desc: "As letters are revealed by the game, type them into the solver to narrow down matches." },
  { num: 3, title: "Win the Round", desc: "Choose the most likely word from our instant results list and secure those points!" }
];
---

<Layout title="Gartic Solver - Word Genie">
  <main class="min-h-screen bg-slate-50 dark:bg-slate-950 pb-32">
    
    <!-- Hero / Title -->
    <section class="pt-32 pb-16 px-6 text-center max-w-4xl mx-auto space-y-6">
       <div class="inline-flex items-center gap-2 px-3 py-1 bg-blue-100 dark:bg-blue-900/30 border border-blue-200 dark:border-blue-800 rounded-full text-[10px] font-bold text-blue-600 dark:text-blue-400 tracking-widest uppercase">
         <span class="w-1.5 h-1.5 rounded-full bg-blue-500 animate-pulse"></span>
         The Ultimate Gartic Companion
       </div>
       <h1 class="text-5xl md:text-7xl font-black tracking-tighter text-slate-900 dark:text-white">
         Gartic Word <span class="text-blue-600">Solver</span>
       </h1>
       <p class="text-lg text-slate-500 dark:text-slate-400 max-w-2xl mx-auto leading-relaxed">
         Decode drawings instantly. Filter by word length and letters to find the answer before anyone else.
       </p>
    </section>

    <!-- Solver Container -->
    <section class="px-6 mb-32">
      <div class="max-w-5xl mx-auto bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 rounded-[40px] p-8 md:p-12 shadow-2xl shadow-slate-200/50 dark:shadow-none">
        <SimpleSolver client:load words={allWords} game="gartic" placeholder="Enter pattern (e.g., ele____, c_t)" />
      </div>
    </section>

    <!-- Content Sections -->
    <div class="container mx-auto px-6 space-y-32">
      
      <!-- Top Categories -->
      <section>
        <div class="flex flex-col md:flex-row justify-between items-end mb-12 gap-4">
           <div>
             <h2 class="text-3xl font-black tracking-tight mb-2">Top Categories</h2>
             <p class="text-slate-500">Explore our curated databases for common game modes.</p>
           </div>
        </div>
        <div class="grid md:grid-cols-3 gap-6">
          {categories.map(c => (
            <div class="bg-white dark:bg-slate-900 border border-slate-100 dark:border-slate-800 p-8 rounded-3xl group hover:border-blue-500/50 transition-all">
               <div class="w-12 h-12 bg-blue-500/10 rounded-xl flex items-center justify-center text-2xl mb-6">{c.icon}</div>
               <h3 class="text-xl font-bold mb-1">{c.name}</h3>
               <p class="text-[10px] font-bold text-slate-400 tracking-wider mb-6 uppercase">{c.count}</p>
               <a href="#" class="inline-flex items-center gap-2 text-blue-600 font-bold text-sm group-hover:gap-3 transition-all">
                 Explore Database <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M17 8l4 4m0 0l-4 4m4-4H3" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
               </a>
            </div>
          ))}
        </div>
      </section>

      <!-- Featured Words -->
      <section>
        <WordShowcase client:load title="Featured Words" words={exampleWords} colorScheme="blue" />
      </section>

      <!-- Process -->
      <section class="text-center">
        <h2 class="text-3xl font-black tracking-tight mb-16">Master Gartic in 3 Steps</h2>
        <div class="grid md:grid-cols-3 gap-12 relative">
          <!-- Connector Line (Desktop) -->
          <div class="hidden md:block absolute top-10 left-1/4 right-1/4 h-px bg-slate-200 dark:bg-slate-800 -z-0"></div>
          
          {steps.map(s => (
            <div class="relative z-10 space-y-6">
              <div class="w-20 h-20 bg-blue-600 text-white rounded-3xl flex items-center justify-center text-2xl font-black mx-auto shadow-xl shadow-blue-600/30">{s.num}</div>
              <h3 class="text-xl font-bold">{s.title}</h3>
              <p class="text-slate-500 dark:text-slate-400 text-sm leading-relaxed max-w-xs mx-auto">{s.desc}</p>
            </div>
          ))}
        </div>
      </section>

    </div>
  </main>
</Layout>