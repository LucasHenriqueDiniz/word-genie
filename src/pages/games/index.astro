---
import Layout from '../../components/Layout.astro';
---

<Layout title="Choose Your Game - Word Genie">
  <main class="min-h-screen">
    <!-- Split Screen -->
    <div class="grid md:grid-cols-2 min-h-[80vh]">
      <!-- Gartic Side -->
      <a
        href="/games/gartic"
        class="group relative flex flex-col justify-center px-8 lg:px-16 py-20 lg:py-24 overflow-hidden transition-all duration-500 bg-gradient-to-br from-primary via-primary to-blue-700 hover:shadow-[inset_0_0_0_4px_rgba(255,255,255,0.3)]"
      >
        <!-- Decorative elements -->
        <div class="absolute top-0 right-0 w-96 h-96 bg-white/10 rounded-full blur-3xl transform translate-x-1/2 -translate-y-1/2 group-hover:scale-110 transition-transform duration-700"></div>
        <div class="absolute bottom-0 left-0 w-64 h-64 bg-blue-300/10 rounded-full blur-2xl transform -translate-x-1/2 translate-y-1/2"></div>

        <div class="relative z-10">
          <div class="inline-flex items-center gap-2 px-3 py-1.5 bg-white/20 backdrop-blur-sm rounded-full text-white/90 text-sm font-semibold mb-8 self-start">
            <span class="w-2 h-2 bg-emerald-400 rounded-full animate-pulse"></span>
            4,187 Words
          </div>

          <h2 class="text-4xl lg:text-6xl font-extrabold tracking-tight text-white mb-4">
            Gartic Phone
          </h2>
          <p class="text-lg text-white/80 max-w-md leading-relaxed mb-8">
            Real-time pattern matching for Gartic.io and Gartic Phone. Multi-language support with category filtering.
          </p>

          <div class="flex items-center gap-3 text-white font-bold text-lg group-hover:gap-5 transition-all">
            <span>Start Matching</span>
            <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6" />
            </svg>
          </div>
        </div>

        <!-- Icon -->
        <div class="absolute top-8 right-8 opacity-20 group-hover:opacity-40 transition-opacity">
          <svg class="w-32 h-32 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1">
            <path stroke-linecap="round" stroke-linejoin="round" d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z" />
          </svg>
        </div>
      </a>

      <!-- GTB Side -->
      <a
        href="/games/guess-build"
        class="group relative flex flex-col justify-center px-8 lg:px-16 py-20 lg:py-24 overflow-hidden transition-all duration-500 bg-gradient-to-br from-tertiary via-tertiary to-amber-800 hover:shadow-[inset_0_0_0_4px_rgba(255,255,255,0.3)]"
      >
        <!-- Decorative elements -->
        <div class="absolute top-0 left-0 w-96 h-96 bg-white/10 rounded-full blur-3xl transform -translate-x-1/2 -translate-y-1/2 group-hover:scale-110 transition-transform duration-700"></div>
        <div class="absolute bottom-0 right-0 w-64 h-64 bg-amber-300/10 rounded-full blur-2xl transform translate-x-1/2 translate-y-1/2"></div>

        <div class="relative z-10">
          <div class="inline-flex items-center gap-2 px-3 py-1.5 bg-white/20 backdrop-blur-sm rounded-full text-white/90 text-sm font-semibold mb-8 self-start">
            <span class="w-2 h-2 bg-emerald-400 rounded-full animate-pulse"></span>
            1,876 Words
          </div>

          <h2 class="text-4xl lg:text-6xl font-extrabold tracking-tight text-white mb-4">
            Guess The Build
          </h2>
          <p class="text-lg text-white/80 max-w-md leading-relaxed mb-8">
            Optimized for Hypixel and Minecraft builds. Creative theme categories and building terminology.
          </p>

          <div class="flex items-center gap-3 text-white font-bold text-lg group-hover:gap-5 transition-all">
            <span>Start Building</span>
            <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6" />
            </svg>
          </div>
        </div>

        <!-- Icon -->
        <div class="absolute top-8 left-8 opacity-20 group-hover:opacity-40 transition-opacity">
          <svg class="w-32 h-32 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1">
            <path stroke-linecap="round" stroke-linejoin="round" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" />
          </svg>
        </div>
      </a>
    </div>

    <!-- Info Section -->
    <section class="py-16 bg-surface-container-low">
      <div class="container-main">
        <div class="grid md:grid-cols-3 gap-8">
          <div class="text-center">
            <div class="w-12 h-12 bg-primary/10 rounded-xl flex items-center justify-center mx-auto mb-4">
              <svg class="w-6 h-6 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z" />
              </svg>
            </div>
            <h3 class="font-bold mb-2">Instant Results</h3>
            <p class="text-sm text-on-surface-variant">Real-time pattern matching as you type</p>
          </div>

          <div class="text-center">
            <div class="w-12 h-12 bg-secondary/10 rounded-xl flex items-center justify-center mx-auto mb-4">
              <svg class="w-6 h-6 text-secondary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
              </svg>
            </div>
            <h3 class="font-bold mb-2">Curated Database</h3>
            <p class="text-sm text-on-surface-variant">Hand-picked words for each game</p>
          </div>

          <div class="text-center">
            <div class="w-12 h-12 bg-tertiary/10 rounded-xl flex items-center justify-center mx-auto mb-4">
              <svg class="w-6 h-6 text-tertiary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z" />
              </svg>
            </div>
            <h3 class="font-bold mb-2">One-Click Copy</h3>
            <p class="text-sm text-on-surface-variant">Copy results instantly to clipboard</p>
          </div>
        </div>
      </div>
    </section>
  </main>
</Layout>
