---
import Layout from '../components/Layout.astro';

const title = 'About Word Genie | Our Mission & Story';
const description = 'Learn about Word Genie, our mission to help gaming communities, and why we created this tool.';
---

<Layout title={title} description={description}>
  <!-- Breadcrumb -->
  <div class="container-main py-4 text-sm">
    <a href="/" class="text-blue-600 hover:underline">Home</a> /
    <span class="text-gray-600 ml-2">About</span>
  </div>

  <!-- Header -->
  <section class="bg-gradient-to-br from-blue-600 to-purple-600 text-white py-12">
    <div class="container-main">
      <h1 class="text-5xl font-bold mb-4">About Word Genie</h1>
      <p class="text-xl text-blue-100">Helping gaming communities have more fun, one word at a time</p>
    </div>
  </section>

  <!-- Content -->
  <div class="container-main py-12 max-w-3xl">
    <section class="mb-12">
      <h2 class="text-3xl font-bold mb-4">Our Mission</h2>
      <p class="text-lg text-gray-700 mb-4">
        Word Genie was created with a simple mission: to enhance the gaming experience for players of Gartic and Guess The Build by providing instant, curated word inspiration.
      </p>
      <p class="text-gray-700 mb-4">
        We believe that having quick access to the right words helps players focus on what they love most—the fun and competition of the games themselves, not searching for ideas.
      </p>
    </section>

    <section class="mb-12">
      <h2 class="text-3xl font-bold mb-4">Why We Built This</h2>
      <p class="text-gray-700 mb-4">
        During Gartic games, we found ourselves constantly searching for words to draw or guess. During Guess The Build, we wanted to build better structures but struggled to find inspiration. We noticed that other players had the same problem.
      </p>
      <p class="text-gray-700 mb-4">
        Rather than keeping the solution to ourselves, we decided to build Word Genie as a free tool for the entire community. What started as a personal project quickly grew into something we knew would help thousands of players worldwide.
      </p>
    </section>

    <section class="mb-12">
      <h2 class="text-3xl font-bold mb-4">What We Offer</h2>
      <ul class="space-y-4 text-gray-700">
        <li class="flex gap-4">
          <span class="text-2xl">🎯</span>
          <div>
            <strong>Curated Word Lists:</strong> Over 500 hand-picked words for each game, organized by category and difficulty
          </div>
        </li>
        <li class="flex gap-4">
          <span class="text-2xl">⚡</span>
          <div>
            <strong>Lightning-Fast Lookup:</strong> Find words instantly with our powerful search and filter system
          </div>
        </li>
        <li class="flex gap-4">
          <span class="text-2xl">💡</span>
          <div>
            <strong>Drawing & Building Tips:</strong> Each word includes helpful strategies for success
          </div>
        </li>
        <li class="flex gap-4">
          <span class="text-2xl">📱</span>
          <div>
            <strong>Mobile-Optimized:</strong> Use Word Genie on any device, during the game itself
          </div>
        </li>
        <li class="flex gap-4">
          <span class="text-2xl">🆓</span>
          <div>
            <strong>100% Free:</strong> No ads, no subscriptions, no hidden costs—forever
          </div>
        </li>
      </ul>
    </section>

    <section class="mb-12">
      <h2 class="text-3xl font-bold mb-4">Affiliations</h2>
      <p class="text-gray-700 mb-4">
        <strong>Important:</strong> Word Genie is not affiliated with, endorsed by, or connected to Gartic Inc., Minecraft, Hypixel, Mojang Studios, or any other game companies.
      </p>
      <p class="text-gray-700 mb-4">
        We are an independent, fan-created tool built to enhance the gaming experience. All trademarks and game titles are the property of their respective owners.
      </p>
    </section>

    <section class="mb-12">
      <h2 class="text-3xl font-bold mb-4">Our Commitment</h2>
      <p class="text-gray-700 mb-4">
        We're committed to:
      </p>
      <ul class="space-y-2 text-gray-700 ml-6">
        <li>✓ Keeping Word Genie free and ad-free</li>
        <li>✓ Maintaining accurate, up-to-date word lists</li>
        <li>✓ Respecting player privacy and data</li>
        <li>✓ Continuously improving our tools and features</li>
        <li>✓ Supporting the gaming communities we serve</li>
      </ul>
    </section>

    <section>
      <h2 class="text-3xl font-bold mb-4">Get in Touch</h2>
      <p class="text-gray-700 mb-4">
        Have suggestions? Found a bug? Want to share your feedback? We'd love to hear from you!
      </p>
      <a href="/contact" class="btn btn-primary">Contact Us</a>
    </section>
  </div>
</Layout>
