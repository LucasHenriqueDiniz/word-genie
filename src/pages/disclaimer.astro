---
import Layout from '../components/Layout.astro';

const title = 'Disclaimer | Word Genie';
const description = 'Important disclaimer about Word Genie and its affiliations.';
---

<Layout title={title} description={description}>
  <!-- Breadcrumb -->
  <div class="container-main py-4 text-sm">
    <a href="/" class="text-blue-600 hover:underline">Home</a> /
    <span class="text-gray-600 ml-2">Disclaimer</span>
  </div>

  <!-- Header -->
  <section class="bg-red-50 border-l-4 border-red-600 py-12">
    <div class="container-main">
      <h1 class="text-4xl font-bold">Disclaimer</h1>
      <p class="text-gray-600 mt-2">Important Information About Word Genie</p>
    </div>
  </section>

  <!-- Content -->
  <div class="container-main py-12 max-w-3xl">
    <section class="mb-8 p-6 bg-red-50 border-l-4 border-red-600 rounded">
      <h2 class="text-2xl font-bold mb-4 text-red-700">Affiliation Disclaimer</h2>
      <p class="text-gray-700 text-lg font-bold">
        Word Genie is NOT affiliated with, endorsed by, or officially connected to:
      </p>
      <ul class="text-gray-700 space-y-2 mt-4 ml-6">
        <li>🎨 <strong>Gartic Inc.</strong> or the game <strong>Gartic</strong></li>
        <li>🎮 <strong>Minecraft, Hypixel Studios</strong>, or <strong>Mojang Studios</strong></li>
        <li>🏢 <strong>Microsoft Corporation</strong></li>
        <li>Any other game companies or trademark holders</li>
      </ul>
      <p class="text-gray-700 mt-4">
        Word Genie is an independent, fan-created tool built to help players enjoy these games more. We are not employees, contractors, or official representatives of any game company.
      </p>
    </section>

    <section class="mb-8">
      <h2 class="text-2xl font-bold mb-4">Trademark Notice</h2>
      <p class="text-gray-700 mb-4">
        All trademarks, logos, and brand names are the exclusive property of their respective owners, including:
      </p>
      <ul class="text-gray-700 space-y-2 ml-6">
        <li><strong>Gartic®</strong> — Registered trademark of Gartic, Inc.</li>
        <li><strong>Minecraft®</strong> — Registered trademark of Mojang Studios</li>
        <li><strong>Hypixel®</strong> — Trademark of Hypixel Studios</li>
        <li><strong>Xbox®</strong> — Registered trademark of Microsoft Corporation</li>
      </ul>
      <p class="text-gray-700 mt-4">
        Use of these names on Word Genie is for informational and reference purposes only.
      </p>
    </section>

    <section class="mb-8">
      <h2 class="text-2xl font-bold mb-4">Fair Use Statement</h2>
      <p class="text-gray-700">
        Word Genie references and uses third-party content solely for:
      </p>
      <ul class="text-gray-700 space-y-2 mt-4 ml-6">
        <li>✓ Educational purposes</li>
        <li>✓ Informational purposes</li>
        <li>✓ Fair use under applicable copyright laws</li>
        <li>✓ Commentary and criticism</li>
      </ul>
      <p class="text-gray-700 mt-4">
        All use is protected under fair use provisions of copyright law.
      </p>
    </section>

    <section class="mb-8">
      <h2 class="text-2xl font-bold mb-4">No Endorsement</h2>
      <p class="text-gray-700">
        The creators and operators of Word Genie do not claim to represent, speak for, or be endorsed by the game companies mentioned above. Word Genie is a completely independent project created by game enthusiasts.
      </p>
    </section>

    <section class="mb-8">
      <h2 class="text-2xl font-bold mb-4">Use at Your Own Risk</h2>
      <p class="text-gray-700">
        Word Genie is provided "as is" without any warranties. Users assume all risks associated with using the tool. We are not responsible for:
      </p>
      <ul class="text-gray-700 space-y-2 mt-4 ml-6">
        <li>Game bans or penalties for tool usage (follow game rules)</li>
        <li>Accuracy of word suggestions</li>
        <li>Technical issues or downtime</li>
        <li>Any damages resulting from use of Word Genie</li>
      </ul>
    </section>

    <section class="mb-8">
      <h2 class="text-2xl font-bold mb-4">Game Policy Compliance</h2>
      <p class="text-gray-700 mb-4">
        Users must ensure their use of Word Genie complies with:
      </p>
      <ul class="text-gray-700 space-y-2 ml-6">
        <li>The Terms of Service of Gartic</li>
        <li>The Terms of Service of Minecraft / Hypixel</li>
        <li>Any server-specific rules or policies</li>
        <li>All applicable laws and regulations</li>
      </ul>
      <p class="text-gray-700 mt-4">
        Word Genie cannot be held responsible if using our tool violates game policies. Always check game rules before using external tools.
      </p>
    </section>

    <section class="mb-8">
      <h2 class="text-2xl font-bold mb-4">Limitation of Liability</h2>
      <p class="text-gray-700">
        Word Genie and its creators shall not be liable for any damages, losses, or injuries resulting from:
      </p>
      <ul class="text-gray-700 space-y-2 mt-4 ml-6">
        <li>Use or inability to use Word Genie</li>
        <li>Game bans or account restrictions</li>
        <li>Accuracy of word suggestions</li>
        <li>Service interruptions or downtime</li>
      </ul>
    </section>

    <section>
      <h2 class="text-2xl font-bold mb-4">Contact</h2>
      <p class="text-gray-700 mb-4">
        If you have concerns about intellectual property or trademark usage, please contact:
      </p>
      <p class="text-gray-700">
        <a href="mailto:legal@wordgenie.app" class="text-blue-600 hover:underline">legal@wordgenie.app</a>
      </p>
    </section>
  </div>
</Layout>
