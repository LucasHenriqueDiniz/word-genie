---
import Layout from '../components/Layout.astro';
import SimpleSolver from '../components/SimpleSolver.tsx';

import garticWordsData from '../data/words/gartic-real.json';
import gtbWordsData from '../data/words/guess-build-real.json';

const title = 'Gartic Word Solver | Pattern Matching Tool | Word Genie';
const description = 'Instantly solve Gartic words using pattern matching. Enter a pattern like "ele____" to find all matching words. Real game vocabulary.';

const garticWords = garticWordsData.words;
const gtbWords = gtbWordsData.words;
---

<Layout title={title} description={description}>
  <div class="container-main py-12">
    <section class="text-center mb-12">
      <h1 class="text-5xl font-bold mb-4">🎨 Gartic Word Solver</h1>
      <p class="text-xl text-gray-600 max-w-3xl mx-auto mb-6">
        Stuck on a Gartic word? Enter what you know and find instant suggestions. Works with {garticWords.length} real game words.
      </p>
    </section>

    <section class="max-w-2xl mx-auto mb-16 bg-white rounded-lg shadow-lg p-8 border-2 border-blue-200">
      <SimpleSolver
        client:load
        words={garticWords}
        game="gartic"
        placeholder="Enter pattern (e.g., ele____, c_t, __a____)"
      />
    </section>

    <section class="max-w-3xl mx-auto mb-16">
      <h2 class="text-3xl font-bold mb-8 text-center">How to Use</h2>
      <div class="grid md:grid-cols-3 gap-6">
        <div class="bg-blue-50 rounded-lg p-6 border border-blue-200">
          <div class="text-3xl font-bold text-blue-600 mb-3">1️⃣</div>
          <h3 class="text-lg font-bold mb-2">Enter Pattern</h3>
          <p class="text-gray-700 text-sm">Type what you know. Use <code class="bg-white px-2 py-1 rounded font-mono">_</code> for unknown letters.</p>
        </div>
        <div class="bg-blue-50 rounded-lg p-6 border border-blue-200">
          <div class="text-3xl font-bold text-blue-600 mb-3">2️⃣</div>
          <h3 class="text-lg font-bold mb-2">See Results</h3>
          <p class="text-gray-700 text-sm">Matching words appear instantly from real gameplay.</p>
        </div>
        <div class="bg-blue-50 rounded-lg p-6 border border-blue-200">
          <div class="text-3xl font-bold text-blue-600 mb-3">3️⃣</div>
          <h3 class="text-lg font-bold mb-2">Copy & Play</h3>
          <p class="text-gray-700 text-sm">Click a word to copy it and paste into your game.</p>
        </div>
      </div>
    </section>

    <section class="max-w-3xl mx-auto">
      <h2 class="text-3xl font-bold mb-8 text-center">FAQ</h2>
      <div class="space-y-4">
        <div class="bg-white rounded-lg p-6 border border-gray-200">
          <h3 class="font-bold text-gray-900 mb-2">What is Gartic?</h3>
          <p class="text-gray-700 text-sm">Gartic is a free online drawing and guessing game where players take turns drawing words while others guess.</p>
        </div>
        <div class="bg-white rounded-lg p-6 border border-gray-200">
          <h3 class="font-bold text-gray-900 mb-2">How does this solver work?</h3>
          <p class="text-gray-700 text-sm">It uses pattern matching to find all words matching your pattern. Enter known letters and use _ for unknown ones.</p>
        </div>
        <div class="bg-white rounded-lg p-6 border border-gray-200">
          <h3 class="font-bold text-gray-900 mb-2">Can I use this while playing?</h3>
          <p class="text-gray-700 text-sm">Yes! Open it alongside your Gartic game and use it whenever you need help guessing a word.</p>
        </div>
      </div>
    </section>

    <section class="mt-16 grid md:grid-cols-3 gap-4">
      <div class="bg-blue-100 border border-blue-300 rounded-lg p-6 text-center">
        <div class="text-4xl font-bold text-blue-600 mb-2">{garticWords.length}</div>
        <div class="text-gray-700 font-semibold">Gartic Words</div>
      </div>
      <div class="bg-orange-100 border border-orange-300 rounded-lg p-6 text-center">
        <div class="text-4xl font-bold text-orange-600 mb-2">{gtbWords.length}</div>
        <div class="text-gray-700 font-semibold">GTB Words</div>
      </div>
      <div class="bg-purple-100 border border-purple-300 rounded-lg p-6 text-center">
        <div class="text-4xl font-bold text-purple-600 mb-2">Instant</div>
        <div class="text-gray-700 font-semibold">Results</div>
      </div>
    </section>
  </div>
</Layout>
