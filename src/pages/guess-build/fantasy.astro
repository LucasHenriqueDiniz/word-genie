---
import Layout from '../../components/Layout.astro';
import SearchBox from '../../components/SearchBox.tsx';
import WordGrid from '../../components/WordGrid.tsx';
import { guessBuildWords } from '../../data/words/guess-build';
import { getWordsByCategory, groupWordsByDifficulty } from '../../lib/search';

const category = 'fantasy';
const words = getWordsByCategory(guessBuildWords, category);
const byDifficulty = groupWordsByDifficulty(words);

const title = 'Guess The Build Fantasy | Magical Building Ideas | Word Genie';
const description = 'Find 40+ magical and fantasy structures for Guess The Build.';
---

<Layout title={title} description={description}>
  <div class="container-main py-4 text-sm">Guess The Build › Fantasy</div>

  <section class="bg-gradient-to-br from-purple-600 to-pink-600 text-white py-12">
    <div class="container-main">
      <h1 class="text-4xl md:text-5xl font-bold mb-4">✨ Guess The Build Fantasy</h1>
      <p class="text-lg text-purple-100">{words.length}+ magical & mythical structures</p>
    </div>
  </section>

  <div class="container-main py-12">
    <div class="grid grid-cols-3 gap-4 mb-8">
      <div class="bg-purple-50 rounded-lg p-4 text-center">
        <div class="text-2xl font-bold text-purple-600">{words.length}</div>
        <div class="text-sm text-gray-600">Fantasy Words</div>
      </div>
      <div class="bg-pink-50 rounded-lg p-4 text-center">
        <div class="text-2xl font-bold text-pink-600">{byDifficulty.easy.length}</div>
        <div class="text-sm text-gray-600">Easy</div>
      </div>
      <div class="bg-red-50 rounded-lg p-4 text-center">
        <div class="text-2xl font-bold text-red-600">{byDifficulty.hard.length}</div>
        <div class="text-sm text-gray-600">Complex</div>
      </div>
    </div>

    <div class="bg-white rounded-lg p-6 mb-8 shadow-sm border border-gray-200">
      <SearchBox client:load words={words} categories={['fantasy']} onSearch={(results) => {}} />
    </div>

    <div class="space-y-8">
      <div>
        <h3 class="text-2xl font-bold mb-4">Easy ({byDifficulty.easy.length})</h3>
        <WordGrid client:load words={byDifficulty.easy} compact={true} />
      </div>
      <div>
        <h3 class="text-2xl font-bold mb-4">Medium ({byDifficulty.medium.length})</h3>
        <WordGrid client:load words={byDifficulty.medium} compact={true} />
      </div>
      <div>
        <h3 class="text-2xl font-bold mb-4">Hard ({byDifficulty.hard.length})</h3>
        <WordGrid client:load words={byDifficulty.hard} compact={true} />
      </div>
    </div>
  </div>
</Layout>
