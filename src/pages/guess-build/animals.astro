---
import Layout from '../../components/Layout.astro';
import SearchBox from '../../components/SearchBox.tsx';
import WordGrid from '../../components/WordGrid.tsx';
import { guessBuildWords } from '../../data/words/guess-build';
import { getWordsByCategory, groupWordsByDifficulty } from '../../lib/search';
import { generateBreadcrumbSchema } from '../../lib/schema';

const category = 'animals';
const words = getWordsByCategory(guessBuildWords, category);
const byDifficulty = groupWordsByDifficulty(words);

const title = 'Guess The Build Animal Structures | Minecraft Building Ideas | Word Genie';
const description = 'Find 50+ animal habitat and structure words for Guess The Build. From chicken coops to dragon lairs!';

const breadcrumbs = [
  { label: 'Home', url: '/' },
  { label: 'Games', url: '/games' },
  { label: 'Guess The Build', url: '/games/guess-build' },
  { label: 'Animals', url: '/guess-build/animals' },
];

const breadcrumbSchema = generateBreadcrumbSchema(breadcrumbs);
---

<Layout title={title} description={description}>
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />

  <div class="container-main py-4 text-sm">
    <a href="/" class="text-blue-600 hover:underline">Home</a> /
    <a href="/games" class="text-blue-600 hover:underline ml-1">Games</a> /
    <a href="/games/guess-build" class="text-blue-600 hover:underline ml-1">Guess The Build</a> /
    <span class="text-gray-600 ml-1">Animals</span>
  </div>

  <section class="bg-gradient-to-br from-green-600 to-emerald-600 text-white py-12">
    <div class="container-main">
      <h1 class="text-4xl md:text-5xl font-bold mb-4">🐾 Guess The Build Animal Structures</h1>
      <p class="text-lg text-green-100">{words.length}+ animal habitats and structures to build</p>
    </div>
  </section>

  <div class="container-main py-12">
    <div class="grid grid-cols-3 gap-4 mb-8">
      <div class="bg-green-50 rounded-lg p-4 text-center">
        <div class="text-2xl font-bold text-green-600">{words.length}</div>
        <div class="text-sm text-gray-600">Animal Concepts</div>
      </div>
      <div class="bg-emerald-50 rounded-lg p-4 text-center">
        <div class="text-2xl font-bold text-emerald-600">{byDifficulty.easy.length}</div>
        <div class="text-sm text-gray-600">Easy Builds</div>
      </div>
      <div class="bg-orange-50 rounded-lg p-4 text-center">
        <div class="text-2xl font-bold text-orange-600">{byDifficulty.hard.length}</div>
        <div class="text-sm text-gray-600">Complex</div>
      </div>
    </div>

    <div class="bg-white rounded-lg p-6 mb-8 border border-gray-200">
      <h2 class="text-2xl font-bold mb-4">Animal Habitats in Guess The Build</h2>
      <p class="text-gray-700">
        Animal words in Guess The Build are about building habitats and structures where animals live. Chicken coops, stables, bird nests, and even dragon lairs! Think about the characteristics of each animal and how to represent them architecturally.
      </p>
    </div>

    <div class="bg-white rounded-lg p-6 mb-8 shadow-sm border border-gray-200">
      <h2 class="text-2xl font-bold mb-4">Find Animal Words</h2>
      <SearchBox client:load words={words} categories={['animals']} onSearch={(results) => {}} />
    </div>

    <div class="space-y-8">
      <div>
        <h3 class="text-2xl font-bold mb-4 flex items-center gap-2">
          <span class="bg-green-100 text-green-700 px-3 py-1 rounded-full text-sm font-bold">EASY</span>
          Easy ({byDifficulty.easy.length})
        </h3>
        <WordGrid client:load words={byDifficulty.easy} compact={true} />
      </div>
      <div>
        <h3 class="text-2xl font-bold mb-4 flex items-center gap-2">
          <span class="bg-yellow-100 text-yellow-700 px-3 py-1 rounded-full text-sm font-bold">MEDIUM</span>
          Medium ({byDifficulty.medium.length})
        </h3>
        <WordGrid client:load words={byDifficulty.medium} compact={true} />
      </div>
      <div>
        <h3 class="text-2xl font-bold mb-4 flex items-center gap-2">
          <span class="bg-red-100 text-red-700 px-3 py-1 rounded-full text-sm font-bold">HARD</span>
          Hard ({byDifficulty.hard.length})
        </h3>
        <WordGrid client:load words={byDifficulty.hard} compact={true} />
      </div>
    </div>
  </div>
</Layout>
