---
import Layout from '../components/Layout.astro';

const title = 'Contact Word Genie | Get in Touch';
const description = 'Have questions, suggestions, or feedback? Contact us and we\'ll get back to you as soon as possible.';
---

<Layout title={title} description={description}>
  <!-- Breadcrumb -->
  <div class="container-main py-4 text-sm">
    <a href="/" class="text-blue-600 hover:underline">Home</a> /
    <span class="text-gray-600 ml-2">Contact</span>
  </div>

  <!-- Header -->
  <section class="bg-gradient-to-br from-blue-600 to-purple-600 text-white py-12">
    <div class="container-main">
      <h1 class="text-5xl font-bold mb-4">Get in Touch</h1>
      <p class="text-xl text-blue-100">We'd love to hear from you</p>
    </div>
  </section>

  <!-- Content -->
  <div class="container-main py-12 max-w-3xl">
    <div class="grid md:grid-cols-2 gap-8 mb-12">
      <div class="card">
        <h3 class="text-2xl font-bold mb-4">📧 Email</h3>
        <p class="text-gray-700 mb-4">
          Have questions or feedback? Email us directly:
        </p>
        <a href="mailto:support@wordgenie.app" class="btn btn-primary">
          support@wordgenie.app
        </a>
      </div>

      <div class="card">
        <h3 class="text-2xl font-bold mb-4">💡 Suggest Words</h3>
        <p class="text-gray-700 mb-4">
          Want to suggest new words for our lists? We're always looking for great ideas!
        </p>
        <a href="mailto:suggest@wordgenie.app" class="btn btn-primary">
          Send Suggestions
        </a>
      </div>
    </div>

    <section class="card">
      <h2 class="text-3xl font-bold mb-6">How We Can Help</h2>

      <div class="space-y-6">
        <div>
          <h3 class="font-bold mb-2">🐛 Report a Bug</h3>
          <p class="text-gray-700">
            Found something not working as expected? Please let us know so we can fix it quickly.
          </p>
        </div>

        <div>
          <h3 class="font-bold mb-2">💬 Feature Requests</h3>
          <p class="text-gray-700">
            Have an idea for a new feature? We'd love to hear it! While we can't implement every suggestion, your feedback helps shape the future of Word Genie.
          </p>
        </div>

        <div>
          <h3 class="font-bold mb-2">📋 Word Suggestions</h3>
          <p class="text-gray-700">
            Know great words that should be in our lists? Submit them and help improve the tool for everyone.
          </p>
        </div>

        <div>
          <h3 class="font-bold mb-2">🤝 Partnerships</h3>
          <p class="text-gray-700">
            Interested in collaborating? We're open to partnerships that benefit the gaming community.
          </p>
        </div>

        <div>
          <h3 class="font-bold mb-2">❓ General Questions</h3>
          <p class="text-gray-700">
            Any other questions? Feel free to reach out anytime.
          </p>
        </div>
      </div>
    </section>

    <div class="mt-8 p-6 bg-blue-50 border-l-4 border-blue-600 rounded">
      <p class="text-gray-700">
        <strong>Response Time:</strong> We aim to respond to all emails within 48 hours. Thank you for your patience!
      </p>
    </div>
  </div>
</Layout>
