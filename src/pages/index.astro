---
import Layout from '../components/Layout.astro';
import { games } from '../data/games';

const features = [
  {
    title: "15,000+ Word Database",
    desc: "Hand-curated vocabulary specifically optimized for Gartic Phone and Hypixel Guess The Build patterns.",
    icon: "database"
  },
  {
    title: "Instant Pattern Matching",
    desc: "Real-time results as you type. Zero lag performance designed for competitive speed runs.",
    icon: "zap"
  },
  {
    title: "Free & No Account",
    desc: "Professional-grade tools with zero cost, zero ads, zero tracking beyond analytics.",
    icon: "unlock"
  }
];

const stats = [
  { value: "15k+", label: "Curated Words" },
  { value: "6k+", label: "Daily Users" },
  { value: "< 50ms", label: "Response Time" },
  { value: "100%", label: "Free Forever" }
];
---

<Layout title="Word Genie - Ultra-Fast Word Solver for Gartic & Guess The Build">
  <!-- Hero -->
  <section class="relative overflow-hidden bg-gradient-to-br from-surface via-surface to-primary/5 py-20 lg:py-28">
    <!-- Background pattern -->
    <div class="absolute inset-0 opacity-30">
      <div class="absolute top-0 left-1/4 w-96 h-96 bg-primary/10 rounded-full blur-3xl"></div>
      <div class="absolute bottom-0 right-1/4 w-80 h-80 bg-secondary/10 rounded-full blur-3xl"></div>
    </div>

    <div class="container-main relative z-10">
      <div class="max-w-4xl mx-auto text-center">
        <!-- Badge -->
        <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-primary/10 border border-primary/20 text-primary text-sm font-semibold mb-8">
          <span class="relative flex h-2 w-2">
            <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-primary opacity-75"></span>
            <span class="relative inline-flex rounded-full h-2 w-2 bg-primary"></span>
          </span>
          Now Optimized for Hypixel 2.0
        </div>

        <!-- Headline -->
        <h1 class="text-4xl sm:text-5xl lg:text-6xl font-extrabold tracking-tight text-on-surface mb-6">
          Dominate Word Games with
          <span class="text-gradient"> Intelligent Matches</span>
        </h1>

        <!-- Subheadline -->
        <p class="text-lg sm:text-xl text-on-surface-variant max-w-2xl mx-auto mb-10 leading-relaxed">
          The precision word solver for Gartic Phone and Guess The Build.
          Real-time pattern matching against 15,000+ curated terms.
          Built for speed, designed for winning.
        </p>

        <!-- CTA Buttons -->
        <div class="flex flex-wrap justify-center gap-4 mb-16">
          <a href="/games" class="btn btn-primary btn-lg">
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z" />
            </svg>
            Launch Solver
          </a>
          <a href="#how-it-works" class="btn btn-secondary btn-lg">
            How It Works
          </a>
        </div>

        <!-- Preview Card -->
        <div class="max-w-lg mx-auto">
          <div class="bg-surface-container-lowest rounded-2xl border border-outline-variant/50 shadow-lg p-6 text-left">
            <div class="flex items-center justify-between text-xs text-on-surface-variant mb-4">
              <span class="font-medium">Pattern: G_N_E</span>
              <span class="px-2 py-0.5 bg-success/10 text-success rounded-full font-semibold">Live</span>
            </div>

            <!-- Letter tiles -->
            <div class="flex justify-center gap-2 mb-4">
              {['G', '_', 'N', '_'].map((l, i) => (
                <div class:list={[
                  "w-14 h-14 flex items-center justify-center text-2xl font-bold rounded-lg",
                  l !== '_'
                    ? "bg-primary/10 border-2 border-primary text-primary"
                    : "bg-surface-container border-2 border-dashed border-outline-variant text-on-surface/40"
                ]}>
                  {l}
                </div>
              ))}
            </div>

            <!-- Results -->
            <div class="space-y-2">
              <div class="flex items-center justify-between p-3 bg-primary/5 border border-primary/30 rounded-lg">
                <span class="font-bold tracking-widest text-primary uppercase">GENIE</span>
                <span class="text-xs bg-primary text-white px-2 py-0.5 rounded font-bold">98% Match</span>
              </div>
              <div class="flex items-center justify-between p-3 bg-surface-container rounded-lg">
                <span class="font-medium tracking-widest text-on-surface-variant uppercase">GENOME</span>
                <span class="text-xs text-on-surface-variant">4 letters</span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Stats -->
  <section class="py-12 bg-surface-container-low border-y border-outline-variant/30">
    <div class="container-main">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-8">
        {stats.map(stat => (
          <div class="text-center">
            <div class="text-3xl lg:text-4xl font-extrabold text-primary mb-1">{stat.value}</div>
            <div class="text-sm text-on-surface-variant font-medium">{stat.label}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Features -->
  <section class="py-20 lg:py-24">
    <div class="container-main">
      <div class="text-center mb-12">
        <h2 class="text-3xl lg:text-4xl font-bold tracking-tight mb-4">Why Word Genie?</h2>
        <p class="text-on-surface-variant max-w-xl mx-auto">
          Built by gamers, for gamers. No fluff, just results.
        </p>
      </div>

      <div class="grid md:grid-cols-3 gap-8 lg:gap-12">
        {features.map(f => (
          <div class="text-center">
            <div class="w-14 h-14 bg-primary/10 rounded-xl flex items-center justify-center mx-auto mb-5 text-primary">
              {f.icon === 'database' && (
                <svg class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M4 7v10c0 2 4 4 8 4s8-2 8-4V7M4 7c0 2 4 4 8 4s8-2 8-4M4 7c0-2 4-4 8-4s8 2 8 4m0 5c0 2-4 4-8 4s-8-2-8-4" />
                </svg>
              )}
              {f.icon === 'zap' && (
                <svg class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z" />
                </svg>
              )}
              {f.icon === 'unlock' && (
                <svg class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M8 11V7a4 4 0 118 0m-4 8v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2z" />
                </svg>
              )}
            </div>
            <h3 class="text-xl font-bold mb-3">{f.title}</h3>
            <p class="text-on-surface-variant text-sm leading-relaxed">{f.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Game Engines -->
  <section id="how-it-works" class="py-20 lg:py-24 bg-surface-container-low">
    <div class="container-main">
      <div class="text-center mb-12">
        <h2 class="text-3xl lg:text-4xl font-bold tracking-tight mb-4">Select Your Game</h2>
        <p class="text-on-surface-variant max-w-xl mx-auto">
          Each engine is fine-tuned for its platform's unique vocabulary and patterns.
        </p>
      </div>

      <div class="grid md:grid-cols-2 gap-6 lg:gap-8 max-w-4xl mx-auto">
        {games.map((game, i) => (
          <a
            href={`/games/${game.slug}`}
            class="group block bg-surface rounded-2xl border border-outline-variant/50 hover:border-primary/50 hover:shadow-lg transition-all duration-300 p-8"
          >
            <div class="flex items-start justify-between mb-6">
              <div class:list={[
                "w-14 h-14 rounded-xl flex items-center justify-center",
                i === 0 ? "bg-primary text-white" : "bg-tertiary text-white"
              ]}>
                {i === 0 ? (
                  <svg class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z" />
                  </svg>
                ) : (
                  <svg class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" />
                  </svg>
                )}
              </div>
              <span class="text-xs font-bold text-on-surface-variant bg-surface-container px-2 py-1 rounded">
                {i === 0 ? "4,187 words" : "1,876 words"}
              </span>
            </div>

            <h3 class="text-2xl font-bold mb-3 group-hover:text-primary transition-colors">{game.name}</h3>
            <p class="text-on-surface-variant text-sm leading-relaxed mb-6">
              {i === 0
                ? "Optimized for Gartic.io and Gartic Phone. Multi-language patterns, category filters, and theme-aware matching."
                : "Engineered for Hypixel and building competitions. Visual-noun associations and creative build terminology."}
            </p>

            <div class="flex items-center gap-2 text-primary font-semibold">
              Start Solving
              <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
              </svg>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-20 lg:py-24">
    <div class="container-narrow text-center">
      <h2 class="text-3xl lg:text-4xl font-bold tracking-tight mb-4">Ready to Win?</h2>
      <p class="text-on-surface-variant mb-8 max-w-lg mx-auto">
        No signup. No ads. No waiting. Just instant results.
      </p>
      <a href="/games" class="btn btn-primary btn-lg">
        Get Started Free
        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6" />
        </svg>
      </a>
    </div>
  </section>
</Layout>
