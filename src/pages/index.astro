---
import Layout from '../components/Layout.astro';
import { WordGenieLogo } from '../components/WordGenieLogo';

const features = [
  {
    title: "15k+ Game Dictionary",
    desc: "Hand-curated database specifically weighted for Gartic and Hypixel game logic.",
    icon: "chip"
  },
  {
    title: "Instant Pattern-Matching",
    desc: "Results update as you type. Zero latency performance optimized for speed-runs.",
    icon: "layers"
  },
  {
    title: "Premium & Always Free",
    desc: "Top-tier aesthetic and professional tools with no subscriptions or accounts required.",
    icon: "shield"
  }
];

const engines = [
  {
    id: "GARTIC_CORE",
    name: "Gartic Solver",
    desc: "Optimized for Gartic.io and Gartic Phone categories. Supports multi-language patterns and complex theme matching.",
    count: "4,187 DEFINITIONS",
    color: "blue",
    href: "/games/gartic"
  },
  {
    id: "BUILD_CORE",
    name: "Guess Build",
    desc: "Engineered for Hypixel and building competitions. Prioritizes visual-noun associations and creative building terminology.",
    count: "1,876 DEFINITIONS",
    color: "orange",
    href: "/games/guess-build"
  }
];
---

<Layout title="Word Genie - Premium Gaming Solver">
  <main class="bg-[#020617] text-white selection:bg-blue-500/30">
    <!-- Hero Section -->
    <section class="relative min-h-[90vh] flex items-center pt-20 overflow-hidden">
      <div class="absolute inset-0 z-0">
        <img src="{{DATA:IMAGE:IMAGE_24}}" alt="Hero Background" class="w-full h-full object-cover opacity-60" />
        <div class="absolute inset-0 bg-gradient-to-b from-transparent via-[#020617]/80 to-[#020617]"></div>
      </div>

      <div class="container mx-auto px-6 relative z-10 grid lg:grid-cols-2 gap-12 items-center">
        <div class="space-y-8">
          <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-blue-500/10 border border-blue-500/20 text-blue-400 text-xs font-bold tracking-widest uppercase">
            <span class="relative flex h-2 w-2">
              <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-blue-400 opacity-75"></span>
              <span class="relative inline-flex rounded-full h-2 w-2 bg-blue-500"></span>
            </span>
            Now Optimized for Hypixel 2.0
          </div>
          
          <h1 class="text-6xl lg:text-8xl font-black tracking-tighter leading-none">
            Intelligent <br/>
            <span class="text-transparent bg-clip-text bg-gradient-to-r from-blue-400 to-cyan-400">Word Mastery</span>
          </h1>
          
          <p class="text-xl text-slate-400 max-w-lg leading-relaxed">
            Dominate Gartic.io and Guess The Build with our precision-engineered engine. Real-time matching against 15,000+ curated terms.
          </p>

          <div class="flex flex-wrap gap-4">
            <a href="#engines" class="px-8 py-4 bg-blue-600 hover:bg-blue-500 text-white font-bold rounded-xl transition-all flex items-center gap-2 shadow-lg shadow-blue-600/20 group">
              Launch Solver
              <svg class="w-5 h-5 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
            </a>
            <button class="px-8 py-4 bg-slate-800/50 hover:bg-slate-800 border border-slate-700 text-slate-300 font-bold rounded-xl transition-all flex items-center gap-2">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 5H6a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2v-1M8 5a2 2 0 002 2h2a2 2 0 002-2M8 5a2 2 0 012-2h2a2 2 0 012 2m0 0h2a2 2 0 012 2v3m2 4H10m0 0l3-3m-3 3l3 3"/></svg>
              One-tap copy enabled
            </button>
          </div>
        </div>

        <!-- Preview Card -->
        <div class="hidden lg:block">
          <div class="glass-card p-1 rounded-3xl bg-gradient-to-br from-white/10 to-transparent border border-white/10 shadow-2xl relative overflow-hidden group">
             <div class="bg-slate-900/80 backdrop-blur-xl p-8 rounded-[22px] space-y-6">
                <div class="flex justify-between items-center text-xs font-mono text-slate-500">
                  <span>ENGINE STATUS: ACTIVE</span>
                  <div class="flex gap-1">
                    <div class="w-2 h-2 rounded-full bg-blue-500"></div>
                    <div class="w-2 h-2 rounded-full bg-slate-700"></div>
                  </div>
                </div>
                <div class="grid grid-cols-4 gap-2">
                   {['G', '_', 'N', '_'].map((l, i) => (
                     <div class={`h-16 flex items-center justify-center text-2xl font-bold rounded-lg border ${l !== '_' ? 'bg-blue-500/20 border-blue-500 text-blue-400' : 'bg-slate-800 border-slate-700 text-slate-600'}`}>
                        {l}
                     </div>
                   ))}
                </div>
                <div class="space-y-2">
                  <div class="p-3 bg-blue-600/20 border border-blue-500/30 rounded-lg flex justify-between items-center">
                    <span class="font-bold tracking-widest text-blue-300 uppercase">GENIE</span>
                    <span class="text-[10px] bg-blue-500 text-white px-1.5 py-0.5 rounded font-bold">98% MATCH</span>
                  </div>
                  <div class="p-3 bg-slate-800/40 border border-slate-700/50 rounded-lg flex justify-between items-center text-slate-500">
                    <span class="font-bold tracking-widest uppercase">GRIN</span>
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M8 5H6a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2v-1M8 5a2 2 0 002 2h2a2 2 0 002-2M8 5a2 2 0 012-2h2a2 2 0 012 2m0 0h2a2 2 0 012 2v3m2 4H10m0 0l3-3m-3 3l3 3" stroke-width="2"/></svg>
                  </div>
                </div>
             </div>
             <!-- Decorative -->
             <div class="absolute -top-12 -right-12 w-24 h-24 bg-blue-500/20 blur-3xl rounded-full"></div>
             <div class="absolute top-4 right-4 p-2 bg-blue-600 rounded-lg shadow-lg shadow-blue-600/50">
               <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-7.714 2.143L11 21l-2.143-7.714L1 12l6.857-2.143L11 3z" stroke-width="2" stroke-linecap="round"/></svg>
             </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Features Section -->
    <section class="py-24 border-y border-slate-800/50 bg-slate-900/20">
      <div class="container mx-auto px-6 grid md:grid-cols-3 gap-12">
        {features.map(f => (
          <div class="space-y-4 text-center">
             <div class="w-12 h-12 bg-blue-500/10 rounded-xl flex items-center justify-center mx-auto text-blue-500">
               {f.icon === 'chip' && <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M9 3v2m6-2v2M9 19v2m6-2v2M5 9H3m2 6H3m18-6h-2m2 6h-2M7 19h10a2 2 0 002-2V7a2 2 0 00-2-2H7a2 2 0 00-2 2v10a2 2 0 002 2zM9 9h6v6H9V9z" stroke-width="2"/></svg>}
               {f.icon === 'layers' && <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M4 10l8 4 8-4M4 14l8 4 8-4m-16-10l8 4 8-4-8-4-8 4z" stroke-width="2"/></svg>}
               {f.icon === 'shield' && <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" stroke-width="2"/></svg>}
             </div>
             <h3 class="text-xl font-bold">{f.title}</h3>
             <p class="text-slate-500 text-sm leading-relaxed">{f.desc}</p>
          </div>
        ))}
      </div>
    </section>

    <!-- Engines Grid -->
    <section id="engines" class="py-32 container mx-auto px-6">
      <div class="flex flex-col md:flex-row justify-between items-end mb-16 gap-4">
        <div>
           <h2 class="text-5xl font-black tracking-tight mb-4">Select Game Engine</h2>
           <p class="text-slate-400">Our specialized engines are fine-tuned for the unique vocabularies of each platform.</p>
        </div>
        <div class="flex items-center gap-4">
          <span class="text-[10px] font-bold tracking-widest text-slate-600 uppercase">Active Engines</span>
          <div class="h-px w-24 bg-slate-800"></div>
        </div>
      </div>

      <div class="grid md:grid-cols-2 gap-8">
        {engines.map(e => (
          <div class="group relative bg-slate-900/40 border border-slate-800 hover:border-blue-500/50 p-10 rounded-[32px] transition-all duration-300">
             <div class="flex justify-between items-start mb-12">
                <div class={`w-16 h-16 rounded-2xl flex items-center justify-center ${e.color === 'blue' ? 'bg-blue-600' : 'bg-orange-600'}`}>
                  {e.color === 'blue' ? (
                    <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z" stroke-width="2" stroke-linecap="round"/></svg>
                  ) : (
                    <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" stroke-width="2" stroke-linecap="round"/></svg>
                  )}
                </div>
                <div class="text-right">
                  <div class="font-mono text-sm font-bold text-slate-300 mb-1">{e.id}</div>
                  <div class="text-[10px] text-slate-500 font-bold tracking-tighter">{e.count}</div>
                </div>
             </div>
             
             <h3 class="text-3xl font-bold mb-4">{e.name}</h3>
             <p class="text-slate-400 mb-8 max-w-sm leading-relaxed">{e.desc}</p>
             
             <a href={e.href} class="inline-flex items-center gap-4 px-6 py-3 bg-white text-slate-950 font-bold rounded-xl hover:bg-slate-200 transition-colors">
               Start Engine
               <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M9 5l7 7-7 7" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
             </a>
             
             <!-- Decorative Corner -->
             <div class={`absolute top-0 right-0 w-32 h-32 blur-[100px] opacity-0 group-hover:opacity-20 transition-opacity rounded-full ${e.color === 'blue' ? 'bg-blue-500' : 'bg-orange-500'}`}></div>
          </div>
        ))}
      </div>
    </section>

    <!-- Footer etc... -->
  </main>
</Layout>

<style>
  .glass-card {
    background: linear-gradient(135deg, rgba(255,255,255,0.05) 0%, rgba(255,255,255,0) 100%);
    backdrop-filter: blur(10px);
  }
</style>