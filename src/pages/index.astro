---
import Layout from '../components/Layout.astro';
import { games } from '../data/games';
import { generateWebApplicationSchema } from '../lib/schema';

const title = 'Word Genie - Word Helper for Gartic & Guess The Build';
const description = 'Get instant word ideas for Gartic and Guess The Build games. Search thousands of words by difficulty and category.';

const schema = generateWebApplicationSchema();
---

<Layout title={title} description={description}>
  <script type="application/ld+json" set:html={JSON.stringify(schema)} />

  <!-- Hero Section -->
  <section class="bg-gradient-to-br from-blue-600 via-purple-600 to-pink-600 text-white py-24 relative overflow-hidden">
    <div class="absolute inset-0 opacity-10">
      <div class="absolute top-20 left-10 w-72 h-72 bg-white rounded-full mix-blend-screen blur-3xl"></div>
      <div class="absolute bottom-10 right-10 w-72 h-72 bg-white rounded-full mix-blend-screen blur-3xl"></div>
    </div>
    <div class="container-main text-center relative z-10">
      <div class="inline-block mb-6 px-4 py-2 bg-white/20 rounded-full border border-white/30">
        <span class="text-sm font-semibold">🎮 For Gamers, By Gamers</span>
      </div>
      <h1 class="text-6xl md:text-7xl font-bold mb-6 leading-tight">
        Word Genie ✨
      </h1>
      <p class="text-2xl md:text-3xl font-semibold mb-6 text-blue-50">
        Master Drawing & Building Games
      </p>
      <p class="text-lg mb-12 max-w-2xl mx-auto text-blue-100 leading-relaxed">
        660+ carefully curated words for Gartic and Guess The Build. Organized by difficulty. Searchable by category. With drawing & building tips.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center mb-12">
        <a href="/games" class="btn bg-white text-blue-600 hover:bg-gray-50 text-lg px-8 py-4 font-bold shadow-lg hover:shadow-xl transition transform hover:scale-105">
          🎯 Start Now (Free)
        </a>
        <a href="/blog" class="btn bg-blue-500 text-white hover:bg-blue-700 text-lg px-8 py-4 font-bold shadow-lg hover:shadow-xl transition transform hover:scale-105">
          📖 Learn Tips
        </a>
      </div>
      <p class="text-sm text-blue-200">
        No login required • Works on any device • Updated regularly
      </p>
    </div>
  </section>

  <!-- Features Section -->
  <section class="container-main py-20">
    <div class="text-center mb-16">
      <h2 class="text-4xl md:text-5xl font-bold mb-4">How Word Genie Works</h2>
      <p class="text-xl text-gray-600">Simple, fast, and designed for game night</p>
    </div>

    <div class="grid md:grid-cols-3 gap-8">
      <div class="card hover:shadow-xl transition border-t-4 border-blue-600 bg-gradient-to-br from-blue-50 to-white">
        <div class="text-6xl mb-4">🎮</div>
        <h3 class="text-2xl font-bold mb-3">Select Your Game</h3>
        <p class="text-gray-700">
          Pick Gartic for drawing words or Guess The Build for Minecraft ideas. Each has 300+ curated words.
        </p>
        <div class="mt-4 text-sm text-blue-600 font-semibold">Learn more →</div>
      </div>

      <div class="card hover:shadow-xl transition border-t-4 border-purple-600 bg-gradient-to-br from-purple-50 to-white">
        <div class="text-6xl mb-4">🔍</div>
        <h3 class="text-2xl font-bold mb-3">Search Smart</h3>
        <p class="text-gray-700">
          Search by word, filter by category, sort by difficulty (easy/medium/hard). Find what you need in seconds.
        </p>
        <div class="mt-4 text-sm text-purple-600 font-semibold">Try it now →</div>
      </div>

      <div class="card hover:shadow-xl transition border-t-4 border-pink-600 bg-gradient-to-br from-pink-50 to-white">
        <div class="text-6xl mb-4">📋</div>
        <h3 class="text-2xl font-bold mb-3">Copy & Win</h3>
        <p class="text-gray-700">
          Click to copy any word. Get drawing tips, building strategies, and win more games with confidence.
        </p>
        <div class="mt-4 text-sm text-pink-600 font-semibold">Get tips →</div>
      </div>
    </div>
  </section>

  <!-- Stats Section -->
  <section class="bg-gradient-to-r from-indigo-600 to-blue-600 text-white py-16">
    <div class="container-main">
      <div class="grid md:grid-cols-4 gap-8 text-center">
        <div>
          <div class="text-5xl font-bold mb-2">660+</div>
          <p class="text-indigo-100">Game Words</p>
          <p class="text-sm text-indigo-200">Carefully curated</p>
        </div>
        <div>
          <div class="text-5xl font-bold mb-2">12</div>
          <p class="text-indigo-100">Categories</p>
          <p class="text-sm text-indigo-200">Organized by type</p>
        </div>
        <div>
          <div class="text-5xl font-bold mb-2">3</div>
          <p class="text-indigo-100">Difficulty Levels</p>
          <p class="text-sm text-indigo-200">Easy to expert</p>
        </div>
        <div>
          <div class="text-5xl font-bold mb-2">2</div>
          <p class="text-indigo-100">Games</p>
          <p class="text-sm text-indigo-200">Plus guides</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Games Section -->
  <section class="bg-gray-50 py-16">
    <div class="container-main">
      <h2 class="text-4xl font-bold mb-4 text-center">Choose Your Game</h2>
      <p class="text-center text-gray-600 mb-12 text-lg">Select a game to explore word lists, tips, and strategies</p>

      <div class="grid md:grid-cols-2 gap-8">
        {games.map(game => (
          <a href={`/games/${game.slug}`} class="group">
            <div class={`card bg-gradient-to-br ${game.color} p-8 text-white transform transition hover:scale-105 cursor-pointer`}>
              <div class="text-6xl mb-4">{game.icon}</div>
              <h3 class="text-2xl font-bold mb-2">{game.name}</h3>
              <p class="text-blue-100 mb-4">{game.description}</p>
              <div class="flex flex-wrap gap-2 mb-4">
                {game.categories.map(cat => (
                  <span key={cat} class="bg-white/20 px-3 py-1 rounded-full text-sm">
                    {cat}
                  </span>
                ))}
              </div>
              <span class="inline-block font-bold group-hover:translate-x-2 transition">
                Explore →
              </span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- FAQ Section -->
  <section class="container-main py-16">
    <h2 class="text-3xl font-bold mb-12 text-center">Frequently Asked Questions</h2>

    <div class="max-w-3xl mx-auto space-y-6">
      <details class="group border-l-4 border-blue-600 bg-gray-50 p-6 rounded">
        <summary class="font-bold cursor-pointer">Can I use Word Genie while playing?</summary>
        <p class="mt-4 text-gray-600">
          Yes! Word Genie is designed to be quick and easy to use during games. Our words load instantly and you can copy them with one click.
        </p>
      </details>

      <details class="group border-l-4 border-blue-600 bg-gray-50 p-6 rounded">
        <summary class="font-bold cursor-pointer">Is this affiliated with Gartic or Minecraft?</summary>
        <p class="mt-4 text-gray-600">
          No. Word Genie is an independent tool created by fans to help players of these games. We are not affiliated with Gartic Inc., Minecraft, Hypixel, or Mojang Studios.
        </p>
      </details>

      <details class="group border-l-4 border-blue-600 bg-gray-50 p-6 rounded">
        <summary class="font-bold cursor-pointer">How often are new words added?</summary>
        <p class="mt-4 text-gray-600">
          We regularly add new words and categories based on popular game trends and user feedback. Check our blog for updates!
        </p>
      </details>

      <details class="group border-l-4 border-blue-600 bg-gray-50 p-6 rounded">
        <summary class="font-bold cursor-pointer">Can I suggest new words?</summary>
        <p class="mt-4 text-gray-600">
          Absolutely! We'd love your suggestions. Visit our <a href="/contact" class="text-blue-600 font-bold">contact page</a> to submit your ideas.
        </p>
      </details>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="bg-gradient-to-r from-blue-600 to-purple-600 text-white py-20">
    <div class="container-main text-center">
      <h2 class="text-5xl font-bold mb-6">Ready to Master Your Games?</h2>
      <p class="text-xl mb-4 text-blue-100 max-w-2xl mx-auto">
        Join thousands of players using Word Genie to find the perfect words and win more games.
      </p>
      <p class="text-blue-200 mb-8">Free. No login. Works on any device.</p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/games" class="btn bg-white text-blue-600 hover:bg-gray-50 text-lg px-8 py-4 font-bold shadow-lg hover:shadow-xl transition">
          Start Searching Now
        </a>
        <a href="/blog" class="btn bg-blue-500 text-white hover:bg-blue-700 text-lg px-8 py-4 font-bold shadow-lg hover:shadow-xl transition">
          Read Tips & Guides
        </a>
      </div>
    </div>
  </section>
</Layout>
