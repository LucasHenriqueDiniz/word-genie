---
import Layout from '../components/Layout.astro';

const title = 'Page Not Found | Word Genie';
const description = 'The page you\'re looking for doesn\'t exist.';
---

<Layout title={title} description={description} noIndex={true}>
  <div class="container-main py-16 text-center">
    <div class="text-6xl mb-4">🔍</div>
    <h1 class="text-5xl font-bold mb-4">404</h1>
    <p class="text-2xl text-gray-600 mb-4">Page Not Found</p>
    <p class="text-lg text-gray-500 mb-8">
      Sorry, we couldn't find the page you're looking for.
    </p>
    <a href="/" class="btn btn-primary text-lg">
      Go Back Home
    </a>
  </div>
</Layout>
