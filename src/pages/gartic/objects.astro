---
import Layout from '../../components/Layout.astro';
import SearchBox from '../../components/SearchBox.tsx';
import WordGrid from '../../components/WordGrid.tsx';
import { garticWords } from '../../data/words/gartic';
import { getWordsByCategory, groupWordsByDifficulty } from '../../lib/search';
import { generateBreadcrumbSchema, generateFAQSchema } from '../../lib/schema';

const category = 'objects';
const words = getWordsByCategory(garticWords, category);
const byDifficulty = groupWordsByDifficulty(words);

const title = 'Gartic Object Words | Drawing Ideas for Common Items | Word Genie';
const description = 'Find object words for Gartic. 50+ drawings of cars, phones, furniture, and more. Organize by difficulty level for perfect gameplay!';

const breadcrumbs = [
  { label: 'Home', url: '/' },
  { label: 'Games', url: '/games' },
  { label: 'Gartic', url: '/games/gartic' },
  { label: 'Objects', url: '/gartic/objects' },
];

const breadcrumbSchema = generateBreadcrumbSchema(breadcrumbs);

const faqs = [
  {
    question: 'What are the easiest object words to draw?',
    answer: 'Simple objects like ball, cup, door, and clock have straightforward shapes. Focus on basic geometric shapes—circles, squares, and lines. Add simple details for recognition.',
  },
  {
    question: 'How do I draw complex objects quickly?',
    answer: 'Break complex objects into simple shapes. A car is rectangles + circles. A guitar is a oval + lines. Draw the main shape first, then add distinctive details.',
  },
  {
    question: 'Are there objects that are too hard?',
    answer: 'Microscope and telescope are challenging because of their complexity. Draw them from the side to show the basic tube shape, then add essential details like lenses.',
  },
  {
    question: 'Should I label objects if my drawing is bad?',
    answer: 'You can\'t label in Gartic, so practice drawing objects beforehand! Focus on drawing recognizable silhouettes rather than perfect details.',
  },
];

const faqSchema = generateFAQSchema(faqs);
---

<Layout title={title} description={description}>
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />

  <div class="container-main py-4 text-sm">
    <a href="/" class="text-blue-600 hover:underline">Home</a> /
    <a href="/games" class="text-blue-600 hover:underline ml-1">Games</a> /
    <a href="/games/gartic" class="text-blue-600 hover:underline ml-1">Gartic</a> /
    <span class="text-gray-600 ml-1">Objects</span>
  </div>

  <section class="bg-gradient-to-br from-blue-600 to-blue-700 text-white py-12">
    <div class="container-main">
      <h1 class="text-4xl md:text-5xl font-bold mb-4">🎨 Gartic Object Words</h1>
      <p class="text-lg text-blue-100 mb-4">
        {words.length}+ everyday items perfect for drawing practice
      </p>
      <p class="text-blue-100 max-w-2xl">
        From simple household items to complex machines, our object word list helps you master drawing common things quickly. Perfect for improving your Gartic skills!
      </p>
    </div>
  </section>

  <div class="container-main py-12">
    <div class="grid grid-cols-3 gap-4 mb-8">
      <div class="bg-blue-50 rounded-lg p-4 text-center">
        <div class="text-2xl font-bold text-blue-600">{words.length}</div>
        <div class="text-sm text-gray-600">Object Words</div>
      </div>
      <div class="bg-indigo-50 rounded-lg p-4 text-center">
        <div class="text-2xl font-bold text-indigo-600">{byDifficulty.easy.length}</div>
        <div class="text-sm text-gray-600">Easy Objects</div>
      </div>
      <div class="bg-orange-50 rounded-lg p-4 text-center">
        <div class="text-2xl font-bold text-orange-600">{byDifficulty.hard.length}</div>
        <div class="text-sm text-gray-600">Complex Items</div>
      </div>
    </div>

    <div class="bg-white rounded-lg p-6 mb-8 border border-gray-200">
      <h2 class="text-2xl font-bold mb-4">Drawing Objects in Gartic</h2>
      <p class="text-gray-700 mb-4">
        Objects make up a large portion of Gartic words. Whether it's household items, vehicles, or instruments, knowing how to draw objects efficiently is key to winning games.
      </p>
      <p class="text-gray-700">
        The secret to drawing objects is understanding their basic geometric shapes. A car is made of rectangles and circles. A phone is a rounded rectangle with a screen. Once you master the basic shapes, adding details becomes much faster.
      </p>
    </div>

    <div class="bg-white rounded-lg p-6 mb-8 shadow-sm border border-gray-200">
      <h2 class="text-2xl font-bold mb-4">Find Object Words</h2>
      <SearchBox
        client:load
        words={words}
        categories={['objects']}
        onSearch={(results) => {}}
      />
    </div>

    <div class="space-y-8">
      <div>
        <h3 class="text-2xl font-bold mb-4 flex items-center gap-2">
          <span class="bg-green-100 text-green-700 px-3 py-1 rounded-full text-sm font-bold">EASY</span>
          Easy Objects ({byDifficulty.easy.length} words)
        </h3>
        <p class="text-gray-600 mb-4">
          Simple household items and common objects with straightforward shapes.
        </p>
        <WordGrid client:load words={byDifficulty.easy} compact={true} />
      </div>

      <div>
        <h3 class="text-2xl font-bold mb-4 flex items-center gap-2">
          <span class="bg-yellow-100 text-yellow-700 px-3 py-1 rounded-full text-sm font-bold">MEDIUM</span>
          Medium Objects ({byDifficulty.medium.length} words)
        </h3>
        <p class="text-gray-600 mb-4">
          Objects with more details and complex shapes.
        </p>
        <WordGrid client:load words={byDifficulty.medium} compact={true} />
      </div>

      <div>
        <h3 class="text-2xl font-bold mb-4 flex items-center gap-2">
          <span class="bg-red-100 text-red-700 px-3 py-1 rounded-full text-sm font-bold">HARD</span>
          Complex Objects ({byDifficulty.hard.length} words)
        </h3>
        <p class="text-gray-600 mb-4">
          Scientific instruments and complex mechanisms that challenge experienced players.
        </p>
        <WordGrid client:load words={byDifficulty.hard} compact={true} />
      </div>
    </div>
  </div>

  <section class="bg-blue-50 py-12">
    <div class="container-main">
      <h2 class="text-3xl font-bold mb-8">Object Drawing Tips</h2>
      <div class="grid md:grid-cols-2 gap-8">
        <div class="card">
          <h3 class="text-xl font-bold mb-4">🎯 Shape-Based Drawing</h3>
          <ul class="space-y-2 text-gray-700">
            <li>• Identify the main shape first (cylinder, sphere, cube)</li>
            <li>• Add major features next (wheels, handle, screen)</li>
            <li>• Include distinctive details (logo, pattern, color)</li>
            <li>• Use perspective to show depth</li>
          </ul>
        </div>
        <div class="card">
          <h3 class="text-xl font-bold mb-4">⏱️ Common Object Categories</h3>
          <ul class="space-y-2 text-gray-700">
            <li>• <strong>Vehicles:</strong> Car, bicycle, train, airplane</li>
            <li>• <strong>Furniture:</strong> Table, chair, bed, cabinet</li>
            <li>• <strong>Electronics:</strong> Phone, computer, television</li>
            <li>• <strong>Musical:</strong> Guitar, piano, violin, drums</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <section class="container-main py-12">
    <h2 class="text-3xl font-bold mb-8">FAQ</h2>
    <div class="max-w-3xl mx-auto space-y-4">
      {faqs.map((faq, i) => (
        <details key={i} class="group border-l-4 border-blue-600 bg-gray-50 p-6 rounded">
          <summary class="font-bold cursor-pointer">{faq.question}</summary>
          <p class="mt-4 text-gray-600">{faq.answer}</p>
        </details>
      ))}
    </div>
  </section>

  <section class="bg-blue-50 border-l-4 border-blue-600 p-6 rounded mt-8">
    <p class="text-sm text-gray-700">
      <strong>Disclaimer:</strong> Word Genie is not affiliated with Gartic, Gartic Inc.
    </p>
  </section>
</Layout>
