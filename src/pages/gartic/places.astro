---
import Layout from '../../components/Layout.astro';
import SearchBox from '../../components/SearchBox.tsx';
import WordGrid from '../../components/WordGrid.tsx';
import { garticWords } from '../../data/words/gartic';
import { getWordsByCategory, groupWordsByDifficulty } from '../../lib/search';
import { generateBreadcrumbSchema } from '../../lib/schema';

const category = 'places';
const words = getWordsByCategory(garticWords, category);
const byDifficulty = groupWordsByDifficulty(words);

const title = 'Gartic Place Words | Locations & Landmarks Drawing Ideas | Word Genie';
const description = 'Find 40+ place words for Gartic. From beaches to castles, draw locations and landmarks with our helpful tips!';

const breadcrumbs = [
  { label: 'Home', url: '/' },
  { label: 'Games', url: '/games' },
  { label: 'Gartic', url: '/games/gartic' },
  { label: 'Places', url: '/gartic/places' },
];

const breadcrumbSchema = generateBreadcrumbSchema(breadcrumbs);
---

<Layout title={title} description={description}>
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />

  <div class="container-main py-4 text-sm">
    <a href="/" class="text-blue-600 hover:underline">Home</a> /
    <a href="/games" class="text-blue-600 hover:underline ml-1">Games</a> /
    <a href="/games/gartic" class="text-blue-600 hover:underline ml-1">Gartic</a> /
    <span class="text-gray-600 ml-1">Places</span>
  </div>

  <section class="bg-gradient-to-br from-amber-600 to-yellow-600 text-white py-12">
    <div class="container-main">
      <h1 class="text-4xl md:text-5xl font-bold mb-4">🏰 Gartic Place Words</h1>
      <p class="text-lg text-amber-100 mb-4">
        {words.length}+ locations and landmarks to draw
      </p>
      <p class="text-amber-100 max-w-2xl">
        From bustling beaches to majestic castles, learn to draw iconic places and locations that everyone recognizes instantly!
      </p>
    </div>
  </section>

  <div class="container-main py-12">
    <div class="grid grid-cols-3 gap-4 mb-8">
      <div class="bg-amber-50 rounded-lg p-4 text-center">
        <div class="text-2xl font-bold text-amber-600">{words.length}</div>
        <div class="text-sm text-gray-600">Place Words</div>
      </div>
      <div class="bg-yellow-50 rounded-lg p-4 text-center">
        <div class="text-2xl font-bold text-yellow-600">{byDifficulty.easy.length}</div>
        <div class="text-sm text-gray-600">Easy Places</div>
      </div>
      <div class="bg-orange-50 rounded-lg p-4 text-center">
        <div class="text-2xl font-bold text-orange-600">{byDifficulty.hard.length}</div>
        <div class="text-sm text-gray-600">Landmarks</div>
      </div>
    </div>

    <div class="bg-white rounded-lg p-6 mb-8 border border-gray-200">
      <h2 class="text-2xl font-bold mb-4">Drawing Places in Gartic</h2>
      <p class="text-gray-700 mb-4">
        Place words are perfect for creative drawing! Unlike objects, places can be drawn from any angle and with varying detail levels. A beach can be just sand and water, or include umbrellas, palm trees, and people.
      </p>
      <p class="text-gray-700">
        The key is drawing iconic elements. A castle needs towers and walls. A beach needs sand and water. A city needs buildings and streets. Focus on what makes each place immediately recognizable.
      </p>
    </div>

    <div class="bg-white rounded-lg p-6 mb-8 shadow-sm border border-gray-200">
      <h2 class="text-2xl font-bold mb-4">Find Place Words</h2>
      <SearchBox
        client:load
        words={words}
        categories={['places']}
        onSearch={(results) => {}}
      />
    </div>

    <div class="space-y-8">
      <div>
        <h3 class="text-2xl font-bold mb-4 flex items-center gap-2">
          <span class="bg-green-100 text-green-700 px-3 py-1 rounded-full text-sm font-bold">EASY</span>
          Easy Places ({byDifficulty.easy.length} words)
        </h3>
        <WordGrid client:load words={byDifficulty.easy} compact={true} />
      </div>

      <div>
        <h3 class="text-2xl font-bold mb-4 flex items-center gap-2">
          <span class="bg-yellow-100 text-yellow-700 px-3 py-1 rounded-full text-sm font-bold">MEDIUM</span>
          Medium Places ({byDifficulty.medium.length} words)
        </h3>
        <WordGrid client:load words={byDifficulty.medium} compact={true} />
      </div>

      <div>
        <h3 class="text-2xl font-bold mb-4 flex items-center gap-2">
          <span class="bg-red-100 text-red-700 px-3 py-1 rounded-full text-sm font-bold">HARD</span>
          Challenging Places ({byDifficulty.hard.length} words)
        </h3>
        <WordGrid client:load words={byDifficulty.hard} compact={true} />
      </div>
    </div>
  </div>

  <section class="bg-amber-50 border-l-4 border-amber-600 p-6 rounded mt-8">
    <p class="text-sm text-gray-700">
      <strong>Disclaimer:</strong> Word Genie is not affiliated with Gartic, Gartic Inc.
    </p>
  </section>
</Layout>
