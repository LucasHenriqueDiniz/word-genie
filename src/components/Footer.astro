---
import { games } from '../data/games';
---

<footer class="bg-inverse-surface text-inverse-on-surface mt-auto">
  <div class="container-main py-12 lg:py-16">
    <div class="grid grid-cols-2 md:grid-cols-4 gap-8 lg:gap-12">
      <!-- Brand -->
      <div class="col-span-2 md:col-span-1">
        <a href="/" class="inline-flex items-center gap-2.5 mb-4 link-clean">
          <div class="w-8 h-8 bg-inverse-primary rounded-lg flex items-center justify-center">
            <svg class="w-4 h-4 text-inverse-surface" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L11 21l-2.143-6.857L1 12l6.857-2.143L11 3z" />
            </svg>
          </div>
          <span class="text-lg font-bold">Word Genie</span>
        </a>
        <p class="text-sm text-inverse-on-surface/70 leading-relaxed mb-4">
          Your intelligent companion for word games. Fast, accurate, and always free.
        </p>
        <p class="text-xs text-inverse-on-surface/50">© 2026 Word Genie</p>
      </div>

      <!-- Games -->
      <div>
        <h4 class="text-label-md uppercase text-inverse-on-surface/50 mb-4">Games</h4>
        <ul class="space-y-2.5">
          {games.map(game => (
            <li>
              <a
                href={`/games/${game.slug}`}
                class="text-sm text-inverse-on-surface/80 hover:text-inverse-on-surface transition-colors"
              >
                {game.name}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Resources -->
      <div>
        <h4 class="text-label-md uppercase text-inverse-on-surface/50 mb-4">Resources</h4>
        <ul class="space-y-2.5">
          <li><a href="/blog" class="text-sm text-inverse-on-surface/80 hover:text-inverse-on-surface transition-colors">Blog</a></li>
          <li><a href="/about" class="text-sm text-inverse-on-surface/80 hover:text-inverse-on-surface transition-colors">About</a></li>
          <li><a href="/contact" class="text-sm text-inverse-on-surface/80 hover:text-inverse-on-surface transition-colors">Contact</a></li>
        </ul>
      </div>

      <!-- Legal -->
      <div>
        <h4 class="text-label-md uppercase text-inverse-on-surface/50 mb-4">Legal</h4>
        <ul class="space-y-2.5">
          <li><a href="/privacy-policy" class="text-sm text-inverse-on-surface/80 hover:text-inverse-on-surface transition-colors">Privacy Policy</a></li>
          <li><a href="/terms" class="text-sm text-inverse-on-surface/80 hover:text-inverse-on-surface transition-colors">Terms of Service</a></li>
          <li><a href="/disclaimer" class="text-sm text-inverse-on-surface/80 hover:text-inverse-on-surface transition-colors">Disclaimer</a></li>
        </ul>
      </div>
    </div>
  </div>

  <!-- Disclaimer Bar -->
  <div class="border-t border-inverse-on-surface/10">
    <div class="container-main py-4">
      <p class="text-xs text-center text-inverse-on-surface/40">
        Word Genie is not affiliated with Gartic, Gartic Inc., Minecraft, Hypixel, or Mojang Studios.
      </p>
    </div>
  </div>
</footer>
