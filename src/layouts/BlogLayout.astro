---
import Layout from '../components/Layout.astro';

interface Props {
  frontmatter: {
    title: string;
    description: string;
    date: string;
    category: string;
    readTime: string;
  };
}

const { frontmatter } = Astro.props;
const formattedDate = new Date(frontmatter.date).toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<Layout title={frontmatter.title} description={frontmatter.description}>
  <article class="container-main py-12 max-w-3xl">
    <!-- Header -->
    <div class="mb-8">
      <div class="flex items-center gap-3 mb-4">
        <span class={`text-xs font-bold px-3 py-1 rounded-full ${
          frontmatter.category === 'Gartic' ? 'bg-blue-100 text-blue-700' :
          frontmatter.category === 'Guess The Build' ? 'bg-orange-100 text-orange-700' :
          'bg-gray-100 text-gray-700'
        }`}>
          {frontmatter.category}
        </span>
        <span class="text-xs text-gray-500">{frontmatter.readTime}</span>
      </div>
      <h1 class="text-5xl font-bold mb-4">{frontmatter.title}</h1>
      <div class="flex items-center gap-4 text-gray-600 mb-8 pb-8 border-b-2">
        <time>{formattedDate}</time>
      </div>
    </div>

    <!-- Content -->
    <div class="prose prose-lg max-w-none">
      <slot />
    </div>

    <!-- Footer CTA -->
    <div class="mt-12 pt-8 border-t-2 bg-blue-50 p-6 rounded-lg">
      <h3 class="text-2xl font-bold mb-3">Ready to Master Your Game?</h3>
      <p class="text-gray-700 mb-4">
        Use Word Genie to find the perfect words for {frontmatter.category}. Search by difficulty, category, and get instant tips!
      </p>
      <a href="/games" class="btn btn-primary">Find Words Now</a>
    </div>

    <!-- Related Posts -->
    <div class="mt-12">
      <h3 class="text-2xl font-bold mb-6">Read More</h3>
      <div class="grid md:grid-cols-2 gap-4">
        <a href="/blog" class="card hover:shadow-lg transition">
          <h4 class="font-bold mb-2">← Back to Blog</h4>
          <p class="text-sm text-gray-600">View all articles and guides</p>
        </a>
        <a href="/games" class="card hover:shadow-lg transition">
          <h4 class="font-bold mb-2">Word Lists →</h4>
          <p class="text-sm text-gray-600">Find words by category and difficulty</p>
        </a>
      </div>
    </div>
  </article>
</Layout>

<style is:global>
  .prose h2 {
    @apply text-3xl font-bold mt-8 mb-4;
  }

  .prose h3 {
    @apply text-2xl font-bold mt-6 mb-3;
  }

  .prose ul, .prose ol {
    @apply my-4 ml-6;
  }

  .prose li {
    @apply my-2;
  }

  .prose a {
    @apply text-blue-600 hover:text-blue-700 font-semibold;
  }

  .prose strong {
    @apply font-bold text-gray-900;
  }

  .prose code {
    @apply bg-gray-100 px-2 py-1 rounded text-sm;
  }

  .prose blockquote {
    @apply border-l-4 border-blue-600 pl-4 italic text-gray-700;
  }
</style>
